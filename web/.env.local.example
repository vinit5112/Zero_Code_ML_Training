# FastAPI (uvicorn). No trailing slash. If you omit NEXT_PUBLIC_API_URL, the app
# uses same-origin /api/* and next.config.ts rewrites to BACKEND_PROXY_URL (default 8000).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Target for Next.js rewrites when NEXT_PUBLIC_API_URL is not set (optional).
# BACKEND_PROXY_URL=http://127.0.0.1:8000
